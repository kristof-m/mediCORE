<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="sk.medicore.controller.RegistraciaController"
           prefWidth="900" prefHeight="650"
           style="-fx-background-color: linear-gradient(to bottom right, #1a9e8f, #1565c0);">

    <VBox alignment="CENTER" maxWidth="420"
          style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 4);"
          spacing="0">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="4" style="-fx-padding: 32 40 20 40;">
            <Label text="MediCORE" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
            <Label text="Vytvorte si účet" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Zaregistrujte sa a spravujte svoje zdravotné rezervácie."
                   style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-text-alignment: center;"
                   wrapText="true"/>
        </VBox>

        <!-- Form -->
        <VBox spacing="12" style="-fx-padding: 0 40 0 40;">

            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Meno" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="menoField" promptText="Vaše meno"
                               style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 1;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Priezvisko" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="priezviskoField" promptText="Vaše priezvisko"
                               style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 1;"/>
                </VBox>
            </HBox>

            <VBox spacing="4">
                <Label text="E-mail" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <TextField fx:id="emailField" promptText="vas@email.com"
                           style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 1;"/>
                <Label fx:id="emailHintLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #888;"
                       visible="false" managed="false"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Heslo" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <PasswordField fx:id="passwordField" promptText="Minimálne 6 znakov"
                               style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 1;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Potvrdiť heslo" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <PasswordField fx:id="passwordConfirmField" promptText="Zopakujte heslo"
                               style="-fx-font-size: 13px; -fx-padding: 10 12; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 1;"/>
            </VBox>

            <!-- Error label -->
            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #d32f2f; -fx-font-size: 12px;"
                   wrapText="true" managed="false" visible="false"/>

            <!-- Submit button -->
            <Button text="Vytvoriť účet" onAction="#handleRegistracia"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 11 0; -fx-background-radius: 6; -fx-cursor: hand;"/>

        </VBox>

        <!-- Footer -->
        <HBox alignment="CENTER" spacing="4" style="-fx-padding: 16 40 28 40;">
            <Label text="Už máte účet?" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
            <Hyperlink text="Prihlásiť sa" onAction="#handleGoToPrihlasenie"
                       style="-fx-font-size: 12px; -fx-text-fill: #1a9e8f;"/>
        </HBox>

    </VBox>
</StackPane>
