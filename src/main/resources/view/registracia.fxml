<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="sk.medicore.controller.RegistraciaController"
           prefWidth="900" prefHeight="650"
           style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #16a596 0%, #1a84b8 52%, #1565c0 100%);">

    <VBox alignment="CENTER" spacing="16">

        <!-- Brand lockup -->
        <HBox alignment="CENTER" spacing="12">
            <Label text="+"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;
                          -fx-min-width: 36; -fx-min-height: 36; -fx-max-width: 36; -fx-max-height: 36;
                          -fx-background-color: white; -fx-background-radius: 9; -fx-alignment: CENTER;"/>
            <VBox spacing="2">
                <Label text="MediCORE"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Healthcare Booking Platform"
                       style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.82);"/>
            </VBox>
        </HBox>

        <!-- Card (440px) -->
        <VBox spacing="0" maxWidth="440"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(10,28,60,0.28), 40, 0.0, 0, 10);">

            <VBox spacing="4" style="-fx-padding: 24 32 12 32;">
                <Label text="Vytvorte si účet"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Zaregistrujte sa ako pacient a spravujte svoje rezervácie."
                       style="-fx-font-size: 12.5px; -fx-text-fill: #6b7280;" wrapText="true"/>
            </VBox>

            <VBox spacing="10" style="-fx-padding: 0 32 0 32;">

                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Meno"
                               style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                        <TextField fx:id="menoField" promptText="Vaše meno"
                                   style="-fx-font-size: 12.5px; -fx-pref-height: 36; -fx-padding: 0 11;
                                          -fx-background-radius: 7; -fx-border-color: #e2e5e9;
                                          -fx-border-radius: 7; -fx-border-width: 1;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Priezvisko"
                               style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                        <TextField fx:id="priezviskoField" promptText="Vaše priezvisko"
                                   style="-fx-font-size: 12.5px; -fx-pref-height: 36; -fx-padding: 0 11;
                                          -fx-background-radius: 7; -fx-border-color: #e2e5e9;
                                          -fx-border-radius: 7; -fx-border-width: 1;"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="E-mail"
                           style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                    <TextField fx:id="emailField" promptText="vas@email.com"
                               style="-fx-font-size: 12.5px; -fx-pref-height: 36; -fx-padding: 0 11;
                                      -fx-background-radius: 7; -fx-border-color: #e2e5e9;
                                      -fx-border-radius: 7; -fx-border-width: 1;"/>
                    <Label text="Na túto adresu budeme posielať potvrdenia rezervácií."
                           style="-fx-font-size: 11px; -fx-text-fill: #9aa0a8;"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Heslo"
                           style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                    <PasswordField fx:id="passwordField" promptText="Minimálne 8 znakov"
                                   style="-fx-font-size: 12.5px; -fx-pref-height: 36; -fx-padding: 0 11;
                                          -fx-background-radius: 7; -fx-border-color: #e2e5e9;
                                          -fx-border-radius: 7; -fx-border-width: 1;"/>
                    <Label text="Aspoň 8 znakov, veľké aj malé písmeno a číslica."
                           style="-fx-font-size: 11px; -fx-text-fill: #9aa0a8;"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Potvrdiť heslo"
                           style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                    <PasswordField fx:id="passwordConfirmField" promptText="Zopakujte heslo"
                                   style="-fx-font-size: 12.5px; -fx-pref-height: 36; -fx-padding: 0 11;
                                          -fx-background-radius: 7; -fx-border-color: #e2e5e9;
                                          -fx-border-radius: 7; -fx-border-width: 1;"/>
                </VBox>

                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px;"
                       wrapText="true" managed="false" visible="false"/>

                <Button text="Vytvoriť účet" onAction="#handleRegistracia"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1a9e8f; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-pref-height: 42; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="4"
                  style="-fx-padding: 14 32 22 32; -fx-border-color: #eef0f3 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <Label text="Už máte účet?" style="-fx-font-size: 12.5px; -fx-text-fill: #4b5360;"/>
                <Hyperlink text="Prihlásiť sa" onAction="#handleGoToPrihlasenie"
                           style="-fx-font-size: 12.5px; -fx-text-fill: #1a9e8f; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
