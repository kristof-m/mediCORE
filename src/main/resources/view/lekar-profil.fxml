<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.LekarProfilController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f6f8;">

    <fx:include fx:id="sidebar" source="sidebar-lekar.fxml"/>

    <VBox HBox.hgrow="ALWAYS">

        <!-- Page heading -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 24 28 16 28;" spacing="12">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="Profil lekára"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Údaje, ktoré vidia pacienti pri rezervácii"
                       style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
            </VBox>
            <Button text="Uložiť zmeny" onAction="#handleSave"
                    style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 13px;
                           -fx-font-weight: bold; -fx-padding: 9 18; -fx-background-radius: 7;
                           -fx-cursor: hand; -fx-border-color: transparent;"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="14" style="-fx-padding: 0 28 28 28;">

                <!-- Teal header banner -->
                <HBox spacing="16" alignment="CENTER_LEFT"
                      style="-fx-background-color: linear-gradient(to right, #1a9e8f, #178b7e);
                             -fx-background-radius: 8; -fx-padding: 18 20;">
                    <Label fx:id="bigAvatarLabel" text="??"
                           style="-fx-min-width: 64; -fx-min-height: 64; -fx-max-width: 64; -fx-max-height: 64;
                                  -fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 32;
                                  -fx-border-color: rgba(255,255,255,0.35); -fx-border-radius: 32; -fx-border-width: 2;
                                  -fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-alignment: CENTER;"/>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label fx:id="headerNameLabel" text=""
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="✓ Overený"
                                   style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: white;
                                          -fx-font-size: 9.5px; -fx-font-weight: bold; -fx-padding: 2 7;
                                          -fx-background-radius: 3;"/>
                        </HBox>
                        <Label fx:id="headerEmailLabel" text=""
                               style="-fx-font-size: 12.5px; -fx-text-fill: rgba(255,255,255,0.88);"/>
                        <Label fx:id="headerRoleLabel" text="Lekár"
                               style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: white;
                                      -fx-font-size: 11px; -fx-font-weight: 600; -fx-padding: 3 10;
                                      -fx-background-radius: 999;"/>
                    </VBox>
                    <HBox spacing="22" alignment="CENTER_RIGHT">
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="statTerminyLabel" text="—"
                                   style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="TERMÍNOV"
                                   style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85);
                                          -fx-font-weight: 500;"/>
                        </VBox>
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="statPacientiLabel" text="—"
                                   style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="PACIENTOV"
                                   style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85);
                                          -fx-font-weight: 500;"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- Personal info card -->
                <VBox spacing="0"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;
                             -fx-padding: 18 20;">
                    <Label text="Osobné údaje"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e; -fx-padding: 0 0 4 0;"/>
                    <Label text="Tieto údaje sa zobrazia pacientom vo výbere lekára."
                           style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8; -fx-padding: 0 0 12 0;"/>
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Meno" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                            <TextField fx:id="menoField"
                                       style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                              -fx-border-radius: 7; -fx-background-radius: 7;
                                              -fx-font-size: 13px; -fx-padding: 8 10;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Priezvisko" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                            <TextField fx:id="priezviskoField"
                                       style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                              -fx-border-radius: 7; -fx-background-radius: 7;
                                              -fx-font-size: 13px; -fx-padding: 8 10;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="E-mail" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                            <TextField fx:id="emailField"
                                       style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                              -fx-border-radius: 7; -fx-background-radius: 7;
                                              -fx-font-size: 13px; -fx-padding: 8 10;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Špecializácia" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                            <TextField fx:id="specializaciaField" editable="false" focusTraversable="false"
                                       style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                              -fx-border-radius: 7; -fx-background-radius: 7;
                                              -fx-font-size: 13px; -fx-padding: 8 10; -fx-text-fill: #9aa0a8;"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Security card -->
                <VBox spacing="0"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;
                             -fx-padding: 18 20;">
                    <Label text="Bezpečnosť"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e; -fx-padding: 0 0 4 0;"/>
                    <Label text="Zmena prihlasovacieho hesla."
                           style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8; -fx-padding: 0 0 12 0;"/>
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Súčasné heslo" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                            <PasswordField fx:id="currentPwField"
                                           style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-font-size: 13px; -fx-padding: 8 10;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Nové heslo" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                            <PasswordField fx:id="newPwField" promptText="Zadajte nové heslo"
                                           style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-font-size: 13px; -fx-padding: 8 10;"/>
                        </VBox>
                    </GridPane>
                    <Label fx:id="pwFeedbackLabel" text="" managed="false" visible="false"
                           style="-fx-font-size: 12px; -fx-text-fill: #d32f2f; -fx-padding: 6 0 0 0;"/>
                </VBox>

                <!-- Feedback label -->
                <Label fx:id="saveFeedbackLabel" text="" managed="false" visible="false"
                       style="-fx-font-size: 12.5px; -fx-text-fill: #1a9e8f; -fx-padding: 0;"/>

                <!-- Bottom buttons -->
                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <Button text="Zrušiť" onAction="#handleCancel"
                            style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 13px;
                                   -fx-padding: 9 18; -fx-background-radius: 7; -fx-cursor: hand;
                                   -fx-border-color: #e2e5e9; -fx-border-radius: 7; -fx-border-width: 1;"/>
                    <Button text="Uložiť zmeny" onAction="#handleSave"
                            style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 13px;
                                   -fx-font-weight: bold; -fx-padding: 9 18; -fx-background-radius: 7;
                                   -fx-cursor: hand; -fx-border-color: transparent;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
