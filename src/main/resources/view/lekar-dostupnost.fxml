<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.LekarDostupnostController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f6f8;">

    <fx:include fx:id="sidebar" source="sidebar-lekar.fxml"/>

    <VBox HBox.hgrow="ALWAYS">

        <!-- Page heading -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 24 28 16 28;" spacing="12">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="Moja dostupnosť"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Definujte termíny, v ktorých ste k dispozícii pacientom"
                       style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
            </VBox>
        </HBox>

        <!-- Week nav bar -->
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-padding: 0 28 10 28;">
            <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 8 10;">
                <Button text="‹" onAction="#handlePrevWeek"
                        style="-fx-min-width: 28; -fx-min-height: 28; -fx-max-width: 28; -fx-max-height: 28;
                               -fx-background-color: #f5f6f8; -fx-background-radius: 6;
                               -fx-font-size: 14px; -fx-cursor: hand; -fx-border-color: transparent;"/>
                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Label fx:id="weekLabel" text=""
                           style="-fx-font-size: 12.5px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                    <Label fx:id="weekSubLabel" text=""
                           style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8;"/>
                </VBox>
                <Button text="›" onAction="#handleNextWeek"
                        style="-fx-min-width: 28; -fx-min-height: 28; -fx-max-width: 28; -fx-max-height: 28;
                               -fx-background-color: #f5f6f8; -fx-background-radius: 6;
                               -fx-font-size: 14px; -fx-cursor: hand; -fx-border-color: transparent;"/>
                <Button text="Dnes" onAction="#handleToday"
                        style="-fx-background-color: #f5f6f8; -fx-border-color: #eef0f3; -fx-border-radius: 6;
                               -fx-border-width: 1; -fx-font-size: 11.5px; -fx-font-weight: 600;
                               -fx-text-fill: #1a1a2e; -fx-padding: 4 12; -fx-cursor: hand; -fx-background-radius: 6;"/>
            </HBox>
        </HBox>

        <!-- Main content: grid + side panel -->
        <HBox HBox.hgrow="ALWAYS" spacing="14" VBox.vgrow="ALWAYS" style="-fx-padding: 0 28 28 28;">

            <!-- Weekly grid -->
            <VBox HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">

                <!-- Day headers -->
                <GridPane fx:id="headerGrid"
                          style="-fx-background-color: #f5f6f8; -fx-border-color: transparent transparent #eef0f3 transparent; -fx-border-width: 1;">
                    <columnConstraints>
                        <ColumnConstraints minWidth="46" maxWidth="46" prefWidth="46"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <!-- time col header (empty) -->
                    <Label text="" GridPane.columnIndex="0" style="-fx-padding: 8 6;"/>
                    <!-- Day labels injected by controller into fx:id="headerGrid" -->
                </GridPane>

                <!-- Scrollable body -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <GridPane fx:id="bodyGrid">
                        <columnConstraints>
                            <ColumnConstraints minWidth="46" maxWidth="46" prefWidth="46"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                    </GridPane>
                </ScrollPane>

                <!-- Legend -->
                <HBox spacing="14" alignment="CENTER_LEFT"
                      style="-fx-padding: 8 12; -fx-border-color: #eef0f3 transparent transparent transparent; -fx-border-width: 1;">
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="" style="-fx-min-width: 10; -fx-min-height: 10; -fx-max-width: 10; -fx-max-height: 10; -fx-background-color: #e8f5f3; -fx-background-radius: 2; -fx-border-color: #1a9e8f; -fx-border-width: 0 0 0 2; -fx-border-radius: 0;"/>
                        <Label text="Voľné" style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="" style="-fx-min-width: 10; -fx-min-height: 10; -fx-max-width: 10; -fx-max-height: 10; -fx-background-color: #fef3c7; -fx-background-radius: 2; -fx-border-color: #d97706; -fx-border-width: 0 0 0 2; -fx-border-radius: 0;"/>
                        <Label text="Obsadené" style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="" style="-fx-min-width: 10; -fx-min-height: 10; -fx-max-width: 10; -fx-max-height: 10; -fx-background-color: #fafafa; -fx-background-radius: 2; -fx-border-color: #e2e5e9; -fx-border-width: 0 0 0 2; -fx-border-radius: 0;"/>
                        <Label text="Nevyplnené" style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8;"/>
                    </HBox>
                </HBox>
            </VBox>

            <!-- Right panel -->
            <VBox minWidth="220" maxWidth="220" spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 14;">

                <Label text="PREHĽAD TÝŽDŇA"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;
                              -fx-letter-spacing: 0.04em;"/>

                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-background-color: #e8f5f3; -fx-background-radius: 6; -fx-padding: 8;">
                        <Label text="✓" style="-fx-font-size: 12px; -fx-text-fill: #1a9e8f; -fx-font-weight: bold;"/>
                        <VBox spacing="1">
                            <Label fx:id="statVolneLabel" text="0"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
                            <Label text="Voľných termínov"
                                   style="-fx-font-size: 10.5px; -fx-text-fill: #1a9e8f;"/>
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-background-color: #fef3c7; -fx-background-radius: 6; -fx-padding: 8;">
                        <Pane fx:id="iconObsadene" minWidth="14" minHeight="14" maxWidth="14" maxHeight="14"/>
                        <VBox spacing="1">
                            <Label fx:id="statObsLabel" text="0"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #92400e;"/>
                            <Label text="Obsadených"
                                   style="-fx-font-size: 10.5px; -fx-text-fill: #92400e;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Separator/>

                <Label text="RÝCHLE PRIDANIE"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                <VBox spacing="6">
                    <Label text="Dátum" style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8; -fx-font-weight: 600;"/>
                    <DatePicker fx:id="quickDatePicker" maxWidth="Infinity"
                                style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                       -fx-border-radius: 6; -fx-background-radius: 6;"/>
                </VBox>

                <HBox spacing="6">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Od" style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8; -fx-font-weight: 600;"/>
                        <ComboBox fx:id="quickFromPicker" maxWidth="Infinity"
                                  style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                         -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Do" style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8; -fx-font-weight: 600;"/>
                        <ComboBox fx:id="quickToPicker" maxWidth="Infinity"
                                  style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                         -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Trvanie (min)" style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8; -fx-font-weight: 600;"/>
                    <ComboBox fx:id="quickDurationPicker" maxWidth="Infinity"
                              style="-fx-background-color: #f5f6f8; -fx-border-color: #e2e5e9;
                                     -fx-border-radius: 6; -fx-background-radius: 6;"/>
                </VBox>

                <Button text="Pridať termíny" maxWidth="Infinity" onAction="#handleQuickAdd"
                        style="-fx-background-color: #1a9e8f; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 0;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-border-color: transparent;"/>

                <Label fx:id="addFeedbackLabel" text="" managed="false" visible="false"
                       style="-fx-font-size: 11.5px; -fx-text-fill: #1a9e8f; -fx-wrap-text: true;"/>
            </VBox>
        </HBox>
    </VBox>
</HBox>
