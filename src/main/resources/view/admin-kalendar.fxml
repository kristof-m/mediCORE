<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.AdminKalendarController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-admin.fxml"/>

    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="16" style="-fx-padding: 28;">

            <!-- Heading + doctor picker -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label text="Kalendár — celá klinika"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                    <Label text="Zvoľte lekára a zobrazte jeho týždenný rozvrh"
                           style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
                </VBox>
                <ComboBox fx:id="lekarCombo" promptText="Vybrať lekára"
                          style="-fx-font-size: 13px; -fx-min-width: 220;"
                          onAction="#handleLekarSelected"/>
            </HBox>

            <!-- Week navigation -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button text="← Predchádzajúci" onAction="#handlePrevWeek"
                        style="-fx-background-color: white; -fx-text-fill: #555; -fx-border-color: #e2e5e9;
                               -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12.5px;
                               -fx-padding: 7 14; -fx-cursor: hand;"/>
                <Label fx:id="weekRangeLabel" text=""
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Button text="Ďalší →" onAction="#handleNextWeek"
                        style="-fx-background-color: white; -fx-text-fill: #555; -fx-border-color: #e2e5e9;
                               -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12.5px;
                               -fx-padding: 7 14; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Dnes" onAction="#handleToday"
                        style="-fx-background-color: white; -fx-text-fill: #1a9e8f; -fx-border-color: #1a9e8f;
                               -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12.5px;
                               -fx-padding: 7 14; -fx-cursor: hand;"/>
            </HBox>

            <!-- Week days (populated by controller) -->
            <VBox fx:id="weekContainer" spacing="14"/>

        </VBox>
    </ScrollPane>
</HBox>
