<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.AdminDashboardController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-admin.fxml"/>

    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="18" style="-fx-padding: 28;">

            <!-- Heading -->
            <VBox spacing="2">
                <Label text="Prehľad kliniky"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label fx:id="todayLabel" text=""
                       style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
            </VBox>

            <!-- Stat cards (3 cols) -->
            <HBox spacing="14">
                <VBox HBox.hgrow="ALWAYS" spacing="4"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 18 16; -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label text="Dnes" style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8;"/>
                    <Label fx:id="statDnes" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
                    <Label text="Termínov dnes celkovo" style="-fx-font-size: 11px; -fx-text-fill: #c0c5cc;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="4"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 18 16; -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label text="Celkovo" style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8;"/>
                    <Label fx:id="statPacienti" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #388e3c;"/>
                    <Label text="Unikátnych pacientov" style="-fx-font-size: 11px; -fx-text-fill: #c0c5cc;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="4"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 18 16; -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label text="Lekári" style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8;"/>
                    <Label fx:id="statLekari" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #7b1fa2;"/>
                    <Label text="Aktívnych lekárov" style="-fx-font-size: 11px; -fx-text-fill: #c0c5cc;"/>
                </VBox>
            </HBox>

            <!-- Today's clinic appointments -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Dnešné termíny — celá klinika"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"
                           HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox fx:id="todayContainer" spacing="10"/>
                <Label fx:id="emptyLabel" text="Dnes nie sú žiadne rezervácie."
                       style="-fx-font-size: 13px; -fx-text-fill: #aaa; -fx-padding: 16 0;"
                       visible="false" managed="false"/>
            </VBox>

        </VBox>
    </ScrollPane>
</HBox>
