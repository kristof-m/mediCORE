<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.SidebarLekarController"
      prefWidth="220"
      style="-fx-background-color: white; -fx-border-color: transparent #eef0f3 transparent transparent; -fx-border-width: 0 1 0 0;"
      spacing="0">

    <!-- Brand -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 20 16 16 16;">
        <Label text="+"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;
                      -fx-min-width: 32; -fx-min-height: 32; -fx-max-width: 32; -fx-max-height: 32;
                      -fx-background-color: #e8f5f3; -fx-background-radius: 8; -fx-alignment: CENTER;"/>
        <VBox spacing="1">
            <Label text="MediCORE"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Lekár"
                   style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8;"/>
        </VBox>
    </HBox>

    <!-- User -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 8 16 14 16; -fx-background-color: #fafbfc; -fx-border-color: #eef0f3 transparent #eef0f3 transparent; -fx-border-width: 1 0 1 0;">
        <Label fx:id="sidebarAvatarLabel" text="??"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;
                      -fx-min-width: 36; -fx-min-height: 36; -fx-max-width: 36; -fx-max-height: 36;
                      -fx-background-color: #1a9e8f; -fx-background-radius: 18; -fx-alignment: CENTER;"/>
        <VBox spacing="1">
            <Label fx:id="sidebarMenoLabel" text=""
                   style="-fx-font-size: 12.5px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Lekár"
                   style="-fx-font-size: 10.5px; -fx-text-fill: #9aa0a8;"/>
        </VBox>
    </HBox>

    <!-- Nav -->
    <VBox style="-fx-padding: 8 8 0 8;" spacing="2">
        <Button fx:id="navDashboard" text="Prehľad" maxWidth="Infinity"
                onAction="#handleNavDashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 6;
                       -fx-cursor: hand; -fx-border-color: transparent;"/>
        <Button fx:id="navKalendar" text="Môj kalendár" maxWidth="Infinity"
                onAction="#handleNavKalendar"
                style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 6;
                       -fx-cursor: hand; -fx-border-color: transparent;"/>
        <Button fx:id="navTerminy" text="Definovať termíny" maxWidth="Infinity"
                onAction="#handleNavTerminy"
                style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 6;
                       -fx-cursor: hand; -fx-border-color: transparent;"/>
        <Button fx:id="navMojiPacienti" text="Moji pacienti" maxWidth="Infinity" onAction="#handleNavMojiPacienti"
                style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 6;
                       -fx-cursor: hand; -fx-border-color: transparent;"/>
        <Button fx:id="navProfil" text="Profil" maxWidth="Infinity" onAction="#handleNavLekarProfil"
                style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 6;
                       -fx-cursor: hand; -fx-border-color: transparent;"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <Button fx:id="logoutBtn" text="Odhlásiť sa" maxWidth="Infinity" onAction="#handleLogout"
            style="-fx-background-color: transparent; -fx-text-fill: #d32f2f; -fx-font-size: 13px;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 12 20; -fx-background-radius: 0;
                   -fx-cursor: hand; -fx-border-color: transparent;"/>
</VBox>
