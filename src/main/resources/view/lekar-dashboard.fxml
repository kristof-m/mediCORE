<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.LekarDashboardController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-lekar.fxml"/>

    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="18" style="-fx-padding: 28;">

            <!-- Greeting + action -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label fx:id="greetingLabel" text=""
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                    <Label fx:id="todayLabel" text=""
                           style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
                </VBox>
                <Button text="+ Definovať termín" onAction="#handleNavTerminy"
                        style="-fx-background-color: #1a9e8f; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 9 16; -fx-background-radius: 7; -fx-cursor: hand;"/>
            </HBox>

            <!-- Stat cards (2 cols) -->
            <HBox spacing="14">
                <HBox HBox.hgrow="ALWAYS" alignment="TOP_LEFT" spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 18 16; -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Dnes" style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8;"/>
                        <Label fx:id="statDnes" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label text="Termínov v dnešnom dni" style="-fx-font-size: 11px; -fx-text-fill: #c0c5cc;"/>
                    </VBox>
                    <Pane fx:id="iconStatDnes" minWidth="34" minHeight="34" maxWidth="34" maxHeight="34"
                          style="-fx-background-color: #e8f5f3; -fx-background-radius: 7;"/>
                </HBox>
                <HBox HBox.hgrow="ALWAYS" alignment="TOP_LEFT" spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 18 16; -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Celkovo" style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8;"/>
                        <Label fx:id="statPacienti" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label text="Unikátnych pacientov" style="-fx-font-size: 11px; -fx-text-fill: #c0c5cc;"/>
                    </VBox>
                    <Pane fx:id="iconStatPacienti" minWidth="34" minHeight="34" maxWidth="34" maxHeight="34"
                          style="-fx-background-color: #e8f3e9; -fx-background-radius: 7;"/>
                </HBox>
            </HBox>

            <!-- Today's schedule -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Dnešný program"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"
                           HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox fx:id="todayContainer" spacing="10"/>
                <VBox fx:id="emptyLabel" alignment="CENTER" spacing="6" visible="false" managed="false"
                      style="-fx-padding: 28 0; -fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label text="Dnes nemáte žiadne rezervácie"
                           style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #9aa0a8;"/>
                    <Label text="Definujte termíny cez tlačidlo vyššie"
                           style="-fx-font-size: 12px; -fx-text-fill: #c0c5cc;"/>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>
</HBox>
