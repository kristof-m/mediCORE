<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.DashboardController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-pacient.fxml"/>

    <!-- Main content -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 32;">

            <!-- Top row: greeting + book button -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="greetingLabel" text="Dobrý deň!"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                    <Label text="Tu je prehľad vašich zdravotných rezervácií."
                           style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
                </VBox>
                <Button text="+ Rezervovať termín" onAction="#handleNavRezervovat"
                        style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

            <!-- Stat cards -->
            <HBox spacing="16">
                <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);" spacing="6">
                    <Label text="Nadchádzajúce" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                    <Label fx:id="statNadchadzajuce" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
                    <Label text="Aktívne rezervácie" style="-fx-font-size: 11px; -fx-text-fill: #aaa;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);" spacing="6">
                    <Label text="Absolvované" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                    <Label fx:id="statAbsolvovane" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #388e3c;"/>
                    <Label text="Minulé rezervácie" style="-fx-font-size: 11px; -fx-text-fill: #aaa;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);" spacing="6">
                    <Label text="Zrušené" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                    <Label fx:id="statZrusene" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e53935;"/>
                    <Label text="Zrušené rezervácie" style="-fx-font-size: 11px; -fx-text-fill: #aaa;"/>
                </VBox>
            </HBox>

            <!-- Upcoming appointments -->
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Nadchádzajúce rezervácie" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="upcomingCountLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                </HBox>
                <VBox fx:id="rezervacieContainer" spacing="10"/>
                <Label fx:id="emptyLabel" text="Žiadne nadchádzajúce rezervácie."
                       style="-fx-font-size: 13px; -fx-text-fill: #aaa; -fx-padding: 20 0;"
                       visible="false" managed="false"/>
            </VBox>

            <!-- Need help -->
            <HBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);"
                  spacing="40" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Potrebujete pomoc?" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Zavolajte nám" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    <Label text="+421 555 0100" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="E-mailová podpora" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    <Label text="support@medicore.sk" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>
</HBox>
