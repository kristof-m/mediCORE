<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.ProfilController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-pacient.fxml"/>

    <!-- Main content -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-padding: 32; -fx-max-width: 600;">

            <Label text="Môj profil" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <!-- Avatar + identity card -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
                  spacing="20" alignment="TOP_LEFT">

                <!-- Avatar row -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label fx:id="avatarLabel" text="AB"
                           style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-min-width: 64; -fx-min-height: 64; -fx-max-width: 64; -fx-max-height: 64; -fx-background-radius: 32; -fx-alignment: CENTER;"/>
                    <VBox spacing="4">
                        <Label fx:id="fullNameLabel" text=""
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label fx:id="typBadge" text="Pacient"
                               style="-fx-background-color: #e8f5f3; -fx-text-fill: #1a9e8f; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 3 10; -fx-background-radius: 10;"/>
                    </VBox>
                </HBox>

                <Separator/>

                <!-- Fields -->
                <VBox spacing="14">
                    <HBox spacing="0">
                        <Label text="Meno a priezvisko" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-min-width: 170;"/>
                        <Label fx:id="menoLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #1a1a2e; -fx-font-weight: bold;"/>
                    </HBox>
                    <HBox spacing="0">
                        <Label text="E-mail" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-min-width: 170;"/>
                        <Label fx:id="emailLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #1a1a2e; -fx-font-weight: bold;"/>
                    </HBox>
                    <HBox spacing="0">
                        <Label text="Typ účtu" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-min-width: 170;"/>
                        <Label fx:id="typLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #1a1a2e; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Stats card -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
                  spacing="16">
                <Label text="Štatistiky rezervácií" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <HBox spacing="16">
                    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 16;" spacing="4" alignment="CENTER">
                        <Label fx:id="statCelkovo" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label text="Celkovo" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #e8f5f3; -fx-background-radius: 8; -fx-padding: 16;" spacing="4" alignment="CENTER">
                        <Label fx:id="statAktivne" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
                        <Label text="Aktívne" style="-fx-font-size: 11px; -fx-text-fill: #1a9e8f;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #fce4ec; -fx-background-radius: 8; -fx-padding: 16;" spacing="4" alignment="CENTER">
                        <Label fx:id="statZrusene" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>
                        <Label text="Zrušené" style="-fx-font-size: 11px; -fx-text-fill: #c62828;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Actions -->
            <HBox spacing="12">
                <Button text="Zmeniť heslo" onAction="#handleChangePassword"
                        style="-fx-background-color: white; -fx-text-fill: #1a1a2e; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button text="Odhlásiť sa" onAction="#handleLogout"
                        style="-fx-background-color: #fce4ec; -fx-text-fill: #c62828; -fx-border-color: transparent; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </ScrollPane>
</HBox>
