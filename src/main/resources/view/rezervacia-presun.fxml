<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.RezervaciaPresunController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <!-- Top bar -->
    <HBox style="-fx-background-color: white; -fx-padding: 14 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);"
          alignment="CENTER_LEFT" spacing="16">
        <Button text="← Späť bez zmien" onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
        <Label text="MediCORE" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;" HBox.hgrow="ALWAYS"/>
        <Label text="Presun rezervácie" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 28 32;">

            <!-- Current booking card -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
                  spacing="10">
                <Label text="Aktuálna rezervácia" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-font-weight: bold;"/>
                <Label fx:id="currentDoctorLabel" text=""
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <HBox spacing="20">
                    <Label fx:id="currentProcedureLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #1a9e8f;"/>
                    <Label fx:id="currentDateLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                </HBox>
            </VBox>

            <!-- Slot picker -->
            <VBox spacing="12">
                <Label text="Vyberte nový termín" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label fx:id="slotsSubLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
                <FlowPane fx:id="slotGrid" hgap="10" vgap="10"/>
                <Label fx:id="noSlotsLabel" text="Žiadne dostupné termíny pre tohto lekára."
                       style="-fx-font-size: 13px; -fx-text-fill: #aaa; -fx-padding: 12 0;"
                       visible="false" managed="false"/>
            </VBox>

            <!-- Confirm section — shown after selecting a slot -->
            <VBox fx:id="confirmSection" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
                  spacing="12">
                <Label text="Potvrdenie presunu" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <HBox spacing="8">
                    <Label text="Pôvodný termín:" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-min-width: 140;"/>
                    <Label fx:id="confirmOldTermin" text="" style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-strikethrough: true;"/>
                </HBox>
                <HBox spacing="8">
                    <Label text="Nový termín:" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-min-width: 140;"/>
                    <Label fx:id="confirmNewTermin" text="" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
                </HBox>
                <HBox spacing="12" style="-fx-padding: 8 0 0 0;">
                    <Button text="Potvrdiť presun" onAction="#handleConfirm"
                            style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Zrušiť výber" onAction="#handleClearSelection"
                            style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-padding: 10 24; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
