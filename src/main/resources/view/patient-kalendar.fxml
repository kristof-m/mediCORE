<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.PatientKalendarController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-pacient.fxml"/>

    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="16" style="-fx-padding: 28 24;">

            <!-- Heading -->
            <VBox spacing="2">
                <Label text="Kalendár"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Prehľad všetkých vašich termínov v tomto mesiaci"
                       style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
            </VBox>

            <!-- Month navigation -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="prevBtn" text="‹" onAction="#handlePrev"
                        style="-fx-background-color: white; -fx-text-fill: #9aa0a8; -fx-font-size: 16px;
                               -fx-min-width: 30; -fx-min-height: 30; -fx-max-width: 30; -fx-max-height: 30;
                               -fx-background-radius: 7; -fx-border-color: #eef0f3; -fx-border-radius: 7;
                               -fx-border-width: 1; -fx-cursor: hand; -fx-alignment: CENTER;"/>
                <Label fx:id="monthLabel" text=""
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Button fx:id="nextBtn" text="›" onAction="#handleNext"
                        style="-fx-background-color: white; -fx-text-fill: #9aa0a8; -fx-font-size: 16px;
                               -fx-min-width: 30; -fx-min-height: 30; -fx-max-width: 30; -fx-max-height: 30;
                               -fx-background-radius: 7; -fx-border-color: #eef0f3; -fx-border-radius: 7;
                               -fx-border-width: 1; -fx-cursor: hand; -fx-alignment: CENTER;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="todayBtn" text="Dnes" onAction="#handleToday"
                        style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 12.5px;
                               -fx-padding: 5 14; -fx-background-radius: 7; -fx-border-color: #eef0f3;
                               -fx-border-radius: 7; -fx-border-width: 1; -fx-cursor: hand;"/>
            </HBox>

            <!-- Calendar card -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;">
                <GridPane fx:id="calGrid" hgap="6" vgap="6"
                          style="-fx-padding: 14;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.2857"/>
                        <ColumnConstraints percentWidth="14.2857"/>
                        <ColumnConstraints percentWidth="14.2857"/>
                        <ColumnConstraints percentWidth="14.2857"/>
                        <ColumnConstraints percentWidth="14.2857"/>
                        <ColumnConstraints percentWidth="14.2857"/>
                        <ColumnConstraints percentWidth="14.2857"/>
                    </columnConstraints>
                </GridPane>

                <!-- Legend -->
                <HBox spacing="14" alignment="CENTER_LEFT"
                      style="-fx-padding: 4 14 14 14; -fx-font-size: 11.5px; -fx-text-fill: #9aa0a8;">
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color: #1a9e8f; -fx-background-radius: 3;
                                      -fx-min-width: 10; -fx-min-height: 10; -fx-max-width: 10; -fx-max-height: 10;"/>
                        <Label text="Naplánované" style="-fx-font-size: 11.5px; -fx-text-fill: #9aa0a8;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color: #388e3c; -fx-background-radius: 3;
                                      -fx-min-width: 10; -fx-min-height: 10; -fx-max-width: 10; -fx-max-height: 10;"/>
                        <Label text="Absolvované" style="-fx-font-size: 11.5px; -fx-text-fill: #9aa0a8;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color: #9aa0a8; -fx-background-radius: 3;
                                      -fx-min-width: 10; -fx-min-height: 10; -fx-max-width: 10; -fx-max-height: 10;"/>
                        <Label text="Zrušené" style="-fx-font-size: 11.5px; -fx-text-fill: #9aa0a8;"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Kliknutím na deň zobrazíte detaily"
                           style="-fx-font-size: 11.5px; -fx-text-fill: #9aa0a8;"/>
                </HBox>
            </VBox>

            <!-- Side panel -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 14;">
                <Label fx:id="selectedDayLabel" text="Vybraný deň"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e; -fx-padding: 0 0 8 0;"/>
                <VBox fx:id="sidePanelRows" spacing="0"/>
                <Label fx:id="noApptsLabel" text="Tento deň nemáte žiadne termíny."
                       style="-fx-font-size: 12px; -fx-text-fill: #9aa0a8; -fx-padding: 6 0;"
                       visible="false" managed="false"/>
            </VBox>

        </VBox>
    </ScrollPane>
</HBox>
