<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.PatientKalendarController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <!-- Sidebar -->
    <VBox prefWidth="220" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 2, 0);"
          spacing="0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 24 20 20 20;">
            <Label text="MediCORE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
        </HBox>
        <VBox alignment="CENTER_LEFT" style="-fx-padding: 0 20 20 20;" spacing="2">
            <Label fx:id="sidebarMenoLabel" text=""
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="sidebarTypLabel" text="Pacient"
                   style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
        </VBox>
        <Separator/>
        <VBox style="-fx-padding: 12 0 0 0;" spacing="2">
            <Button text="Dashboard" maxWidth="Infinity" onAction="#handleNavDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Moje rezervácie" maxWidth="Infinity" onAction="#handleNavRezervacje"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Rezervovať termín" maxWidth="Infinity" onAction="#handleNavRezervovat"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Zobraziť kalendár" maxWidth="Infinity"
                    style="-fx-background-color: #e8f5f3; -fx-text-fill: #1a9e8f; -fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Profil" maxWidth="Infinity" onAction="#handleNavProfil"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Odhlásiť sa" maxWidth="Infinity" onAction="#handleLogout"
                style="-fx-background-color: transparent; -fx-text-fill: #d32f2f; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 14 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
    </VBox>

    <!-- Main content -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 32;">

            <Label text="Kalendár termínov" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <!-- Doctor picker -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
                  spacing="10">
                <Label text="Vybrať lekára" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-font-weight: bold;"/>
                <ComboBox fx:id="lekarCombo" maxWidth="Infinity" promptText="— Vyberte lekára —"
                          onAction="#handleLekarSelected"
                          style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Slots grouped by day -->
            <VBox fx:id="dniContainer" spacing="16"/>

            <Label fx:id="emptyLabel" text="Tento lekár nemá žiadne dostupné termíny v najbližších 30 dňoch."
                   style="-fx-font-size: 13px; -fx-text-fill: #aaa; -fx-padding: 12 0;"
                   visible="false" managed="false"/>

        </VBox>
    </ScrollPane>
</HBox>
