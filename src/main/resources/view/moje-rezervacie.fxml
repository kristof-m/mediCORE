<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.MojeRezervacieController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <!-- Sidebar -->
    <VBox prefWidth="220" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 2, 0);"
          spacing="0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 24 20 20 20;">
            <Label text="MediCORE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
        </HBox>
        <VBox alignment="CENTER_LEFT" style="-fx-padding: 0 20 20 20;" spacing="2">
            <Label fx:id="sidebarMenoLabel" text="" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="sidebarTypLabel" text="Pacient" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
        </VBox>
        <Separator/>
        <VBox style="-fx-padding: 12 0 0 0;" spacing="2">
            <Button text="Dashboard" maxWidth="Infinity" onAction="#handleNavDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Moje rezervácie" maxWidth="Infinity" onAction="#handleNavRezervacje"
                    style="-fx-background-color: #e8f5f3; -fx-text-fill: #1a9e8f; -fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Rezervovať termín" maxWidth="Infinity" onAction="#handleNavRezervovat"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Profil" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Odhlásiť sa" maxWidth="Infinity" onAction="#handleLogout"
                style="-fx-background-color: transparent; -fx-text-fill: #d32f2f; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 14 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
    </VBox>

    <!-- Main content -->
    <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 32;" spacing="20">

        <HBox alignment="CENTER_LEFT">
            <Label text="Moje rezervácie" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" HBox.hgrow="ALWAYS"/>
            <Button text="+ Rezervovať termín" onAction="#handleNavRezervovat"
                    style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>

        <!-- Tabs -->
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-tab-min-width: 120;">
            <Tab text="Nadchádzajúce">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="upcomingContainer" spacing="10" style="-fx-padding: 16 0 0 0;"/>
                </ScrollPane>
            </Tab>
            <Tab text="Minulé">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="pastContainer" spacing="10" style="-fx-padding: 16 0 0 0;"/>
                </ScrollPane>
            </Tab>
            <Tab text="Zrušené">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="cancelledContainer" spacing="10" style="-fx-padding: 16 0 0 0;"/>
                </ScrollPane>
            </Tab>
        </TabPane>
    </VBox>
</HBox>
