<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.MojeRezervacieController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-pacient.fxml"/>

    <VBox HBox.hgrow="ALWAYS" spacing="0">

        <!-- Header bar -->
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 24 28 16 28;">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="Moje rezervácie"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Spravujte svoje nadchádzajúce, minulé a zrušené termíny"
                       style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
            </VBox>
            <Button text="+ Nový termín" onAction="#handleNavRezervovat"
                    style="-fx-background-color: #1a9e8f; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-padding: 9 16; -fx-background-radius: 7; -fx-cursor: hand;"/>
        </HBox>

        <!-- Tabs -->
        <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
                 style="-fx-tab-min-width: 130; -fx-background-color: transparent; -fx-padding: 0 20 20 20;">
            <Tab text="Nadchádzajúce">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="upcomingContainer" spacing="10" style="-fx-padding: 14 0 0 0;"/>
                </ScrollPane>
            </Tab>
            <Tab text="Minulé">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="pastContainer" spacing="10" style="-fx-padding: 14 0 0 0;"/>
                </ScrollPane>
            </Tab>
            <Tab text="Zrušené">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="cancelledContainer" spacing="10" style="-fx-padding: 14 0 0 0;"/>
                </ScrollPane>
            </Tab>
        </TabPane>
    </VBox>
</HBox>
