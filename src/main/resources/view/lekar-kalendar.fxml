<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.LekarKalendarController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-lekar.fxml"/>

    <!-- Main content -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 32;">

            <!-- Week navigation -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label text="Môj kalendár" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                    <Label fx:id="weekRangeLabel" text=""
                           style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
                </VBox>
                <Button text="← Predchádzajúci" onAction="#handlePrevWeek"
                        style="-fx-background-color: white; -fx-text-fill: #555; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Button text="Ďalší →" onAction="#handleNextWeek"
                        style="-fx-background-color: white; -fx-text-fill: #555; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>

            <!-- Week days container (empty state rendered inside by controller) -->
            <VBox fx:id="weekContainer" spacing="16"/>

        </VBox>
    </ScrollPane>
</HBox>
