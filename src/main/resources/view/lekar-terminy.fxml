<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.LekarTerminyController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <!-- Sidebar -->
    <VBox prefWidth="220" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 2, 0);"
          spacing="0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 24 20 20 20;">
            <Label text="MediCORE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a9e8f;"/>
        </HBox>
        <VBox alignment="CENTER_LEFT" style="-fx-padding: 0 20 20 20;" spacing="2">
            <Label fx:id="sidebarMenoLabel" text=""
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Lekár" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
        </VBox>
        <Separator/>
        <VBox style="-fx-padding: 12 0 0 0;" spacing="2">
            <Button text="Môj kalendár" maxWidth="Infinity" onAction="#handleNavKalendar"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Definovať termíny" maxWidth="Infinity"
                    style="-fx-background-color: #e8f5f3; -fx-text-fill: #1a9e8f; -fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Moji pacienti" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="Profil" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Odhlásiť sa" maxWidth="Infinity" onAction="#handleLogout"
                style="-fx-background-color: transparent; -fx-text-fill: #d32f2f; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 14 20; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: transparent;"/>
    </VBox>

    <!-- Main content -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-padding: 32;">

            <Label text="Definovať termíny" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <!-- Add slot form -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
                  spacing="16">
                <Label text="Pridať nový termín" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="6">
                        <Label text="Dátum" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <DatePicker fx:id="datePicker" prefWidth="160"
                                    style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Hodina" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <ComboBox fx:id="hourPicker" prefWidth="90"
                                  style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Minúty" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <ComboBox fx:id="minutePicker" prefWidth="90"
                                  style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Trvanie" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <ComboBox fx:id="durationPicker" prefWidth="130"
                                  style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="Pridať termín" onAction="#handleAdd"
                            style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Label fx:id="feedbackLabel" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #d32f2f;"/>
                </HBox>
            </VBox>

            <!-- Existing slots list -->
            <VBox spacing="10">
                <Label text="Moje termíny" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <VBox fx:id="terminyContainer" spacing="8"/>
                <Label fx:id="emptyLabel" text="Nemáte definované žiadne termíny."
                       style="-fx-font-size: 13px; -fx-text-fill: #aaa; -fx-padding: 12 0;"
                       visible="false" managed="false"/>
            </VBox>

        </VBox>
    </ScrollPane>
</HBox>
