<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.LekarTerminyController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-lekar.fxml"/>

    <!-- Main content -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-padding: 32;">

            <Label text="Definovať termíny" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <!-- Add slot form -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
                  spacing="16">
                <Label fx:id="formTitle" text="Pridať nový termín" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="6">
                        <Label text="Dátum" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <DatePicker fx:id="datePicker" prefWidth="160"
                                    style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Hodina" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <ComboBox fx:id="hourPicker" prefWidth="90"
                                  style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Minúty" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <ComboBox fx:id="minutePicker" prefWidth="90"
                                  style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Trvanie" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                        <ComboBox fx:id="durationPicker" prefWidth="130"
                                  style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button fx:id="submitBtn" text="Pridať termín" onAction="#handleAdd"
                            style="-fx-background-color: #1a9e8f; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button fx:id="cancelEditBtn" text="Zrušiť úpravu" onAction="#handleCancelEdit"
                            visible="false" managed="false"
                            style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-padding: 10 20; -fx-cursor: hand;"/>
                    <Label fx:id="feedbackLabel" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #d32f2f;"/>
                </HBox>
            </VBox>

            <!-- Existing slots list -->
            <VBox spacing="10">
                <Label text="Moje termíny" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <VBox fx:id="terminyContainer" spacing="8"/>
                <Label fx:id="emptyLabel" text="Nemáte definované žiadne termíny."
                       style="-fx-font-size: 13px; -fx-text-fill: #aaa; -fx-padding: 12 0;"
                       visible="false" managed="false"/>
            </VBox>

        </VBox>
    </ScrollPane>
</HBox>
