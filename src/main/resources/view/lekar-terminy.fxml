<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sk.medicore.controller.LekarTerminyController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f5f5f5;">

    <fx:include fx:id="sidebar" source="sidebar-lekar.fxml"/>

    <VBox HBox.hgrow="ALWAYS">

        <!-- Heading -->
        <VBox spacing="2" style="-fx-padding: 28 28 16 28;">
            <Label text="Definovať termíny"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Pridajte nové voľné termíny alebo upravte existujúce"
                   style="-fx-font-size: 12.5px; -fx-text-fill: #9aa0a8;"/>
        </VBox>

        <!-- Two-column split -->
        <HBox spacing="16" VBox.vgrow="ALWAYS" style="-fx-padding: 0 28 28 28;">

            <!-- Left: Add/Edit form card (fixed 280px) -->
            <VBox minWidth="280" maxWidth="280" spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #eef0f3; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 16;">

                <Label fx:id="formTitle" text="Pridať nový termín"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                <!-- Date -->
                <VBox spacing="5">
                    <Label text="Dátum" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                style="-fx-background-color: white; -fx-border-color: #e2e5e9;
                                       -fx-border-radius: 7; -fx-background-radius: 7;"/>
                </VBox>

                <!-- Hour + Minute -->
                <HBox spacing="8">
                    <VBox HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Hodina" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                        <ComboBox fx:id="hourPicker" maxWidth="Infinity"
                                  style="-fx-background-color: white; -fx-border-color: #e2e5e9;
                                         -fx-border-radius: 7; -fx-background-radius: 7;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Minúty" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                        <ComboBox fx:id="minutePicker" maxWidth="Infinity"
                                  style="-fx-background-color: white; -fx-border-color: #e2e5e9;
                                         -fx-border-radius: 7; -fx-background-radius: 7;"/>
                    </VBox>
                </HBox>

                <!-- Duration -->
                <VBox spacing="5">
                    <Label text="Trvanie (min)" style="-fx-font-size: 11.5px; -fx-font-weight: bold; -fx-text-fill: #2a2f3a;"/>
                    <ComboBox fx:id="durationPicker" maxWidth="Infinity"
                              style="-fx-background-color: white; -fx-border-color: #e2e5e9;
                                     -fx-border-radius: 7; -fx-background-radius: 7;"/>
                </VBox>

                <!-- Submit + Cancel buttons -->
                <Button fx:id="submitBtn" text="+ Pridať termín" onAction="#handleAdd"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1a9e8f; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 9 0; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button fx:id="cancelEditBtn" text="Zrušiť úpravu" onAction="#handleCancelEdit"
                        maxWidth="Infinity" visible="false" managed="false"
                        style="-fx-background-color: transparent; -fx-text-fill: #888;
                               -fx-border-color: #d0d3d8; -fx-border-radius: 7; -fx-background-radius: 7;
                               -fx-font-size: 13px; -fx-padding: 9 0; -fx-cursor: hand;"/>

                <Label fx:id="feedbackLabel" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #388e3c;" wrapText="true"/>

            </VBox>

            <!-- Right: Slot list -->
            <VBox HBox.hgrow="ALWAYS" spacing="10">
                <Label text="Moje termíny"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="terminyContainer" spacing="8"/>
                </ScrollPane>

                <Label fx:id="emptyLabel" text="Nemáte definované žiadne termíny."
                       style="-fx-font-size: 13px; -fx-text-fill: #aaa; -fx-padding: 12 0;"
                       visible="false" managed="false"/>
            </VBox>

        </HBox>
    </VBox>
</HBox>
